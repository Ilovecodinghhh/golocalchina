# Database — PostgreSQL for production, SQLite for local dev
# For Railway: add a PostgreSQL plugin and set DATABASE_URL automatically
DATABASE_URL=postgresql+asyncpg://glc:glc_secret@localhost:5432/golocalchina

# JWT — REQUIRED in production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=your-secret-key-here-generate-a-real-one
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated allowed origins
CORS_ORIGINS=https://golocalchina.vercel.app,http://localhost:3000
